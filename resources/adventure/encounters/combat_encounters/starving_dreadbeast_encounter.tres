encounter_id = "starving_dreadbeast_encounter"
encounter_name = "A Starving Dreadbeast!"
description = "A gaunt, twisted beast slinks from the undergrowth — all ribs and hunger. Its empty eyes fix on you, and its jaws work as though already feeding."
text_description_completed = "The Starving Dreadbeast lies still. Its hunger, at last, is sated."
