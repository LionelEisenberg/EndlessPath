; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="EndlessPath"
run/main_scene="uid://dyrsbe5x01lgo"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

PersistenceManager="*res://singletons/persistence_manager/persistence_manager.gd"
CultivationManager="*res://singletons/cultivation_manager/cultivation_manager.gd"
EventManager="*res://singletons/event_manager/event_manager.gd"
CharacterManager="*res://singletons/character_manager/character_manager.gd"
UnlockManager="*res://singletons/unlock_manager/unlock_manager.gd"
ResourceManager="*res://singletons/resource_manager/resource_manager.gd"
ZoneManager="*res://singletons/zone_manager/zone_manager.gd"
ActionManager="*res://singletons/action_manager/action_manager.gd"
InventoryManager="*res://singletons/inventory_manager/inventory_manager.gd"
Dialogic="*uid://ds2q0uclmolvu"
DialogueManager="*res://singletons/dialogue_manager/dialogue_manager.gd"
PlayerManager="*res://singletons/player_manager/player_manager.gd"
LogManager="*res://singletons/log_manager/log_manager.gd"
CyclingManager="*res://singletons/cycling_manager/cycling_manager.gd"
AbilityManager="*res://singletons/ability_manager/ability_manager.gd"
PathManager="*res://singletons/path_manager/path_manager.gd"
QuestManager="*res://singletons/quest_manager/quest_manager.gd"

[dialogic]

directories/dch_directory={
"celestial_intervener": "res://assets/dialogue/characters/celestial_intervener/celestial_intervener.dch",
"wisened_dirt_eel": "res://assets/dialogue/characters/wisened_dirt_eel/wisened_dirt_eel.dch"
}
directories/dtl_directory={
"celestial_intervener_introduction_1": "res://assets/dialogue/timelines/celestial_intervener_introduction_1.dtl",
"wandering_spirit_2": "res://assets/dialogue/timelines/rwr.dtl",
"wandering_spirit_3": "res://assets/dialogue/timelines/wandering_spirit_3.dtl"
}
layout/style_directory={
"": "res://assets/dialogue/styles/default_style.tres",
"default_style": "res://assets/dialogue/styles/default_style.tres"
}
layout/style_list=["res://assets/dialogue/styles/default_style.tres"]
layout/default_style="res://assets/dialogue/styles/default_style.tres"
glossary/default_case_sensitive=true
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/AsepriteWizard/plugin.cfg", "res://addons/ResourcePlus/plugin.cfg", "res://addons/dialogic/plugin.cfg", "res://addons/godot_context_exporter/plugin.cfg", "res://addons/gut/plugin.cfg", "res://addons/script-ide/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "purple",
"res://resources/": "yellow",
"res://scenes/": "red",
"res://scripts/": "green",
"res://singletons/": "pink"
}

[gui]

theme/custom="uid://yqkvsb5q7pab"

